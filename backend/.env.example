# ===========================================
# Tree Insurance - Environment Variables
# ===========================================

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Session Configuration
# Generate a strong secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=generate_a_strong_random_secret_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Production Settings
# Set NODE_ENV=production in production environment for secure cookies
