{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "name": "tree-insurance-backend",
      "version": "1.1.0",
      "engines": {
        "node": ">=18.0.0"
      }
    }
  },
  "deploy": {
    "numInstances": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "runtime": {
      "port": 3000,
      "env": {
        "PORT": "3000"
      }
    }
  }
}
